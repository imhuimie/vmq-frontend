# 【通用】环境变量

#  版本号
VITE_VERSION = 2.4.2.9

# 端口号
VITE_PORT = 3006

# 网站地址前缀
VITE_BASE_URL = '/'

# API 地址前缀
VITE_API_URL = '/'

# VMQ API 地址（支持完整URL或相对路径）
VITE_VMQ_API_URL = '/api/'

# 权限模式（ frontend ｜ backend ）
VITE_ACCESS_MODE = frontend

# 跨域请求时是否携带 Cookie（默认使用 Bearer Token，不依赖 Cookie）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥
VITE_LOCK_ENCRYPT_KEY = s3cur3k3y4adpro
