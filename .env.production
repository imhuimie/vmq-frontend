# 【生产】环境变量

# 网站地址前缀
VITE_BASE_URL = /

# API 地址前缀
VITE_API_URL = '/'

# VMQ API 地址（生产环境）
# 相对路径：使用 '/api/' 通过同域名访问
VITE_VMQ_API_URL = '/api/'
# 完整URL：如果后端在不同服务器，请同步修改 VITE_API_URL 为实际后端根地址，例如：
# VITE_API_URL = 'https://api.your-domain.com/'
# VITE_VMQ_API_URL = 'https://api.your-domain.com/api/'

# Delete console
VITE_DROP_CONSOLE = true
